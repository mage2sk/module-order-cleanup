<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_order_deletion_log_listing.panth_order_deletion_log_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_order_deletion_log_columns</spinner>
        <deps>
            <dep>panth_order_deletion_log_listing.panth_order_deletion_log_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="panth_order_deletion_log_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_OrderCleanup::view_log</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_order_deletion_log_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>log_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_order_deletion_log_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>log_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="log_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="order_increment_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Order #</label>
            </settings>
        </column>
        <column name="customer_name" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer</label>
            </settings>
        </column>
        <column name="customer_email" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Email</label>
            </settings>
        </column>
        <column name="grand_total" class="Magento\Sales\Ui\Component\Listing\Column\Price" sortOrder="50">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Grand Total</label>
            </settings>
        </column>
        <column name="order_status" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">Status at Deletion</label>
            </settings>
        </column>
        <column name="items_count" sortOrder="70">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Items</label>
            </settings>
        </column>
        <column name="invoices_deleted" sortOrder="80">
            <settings>
                <filter>select</filter>
                <label translate="true">Invoices Deleted</label>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <dataType>select</dataType>
            </settings>
        </column>
        <column name="shipments_deleted" sortOrder="90">
            <settings>
                <filter>select</filter>
                <label translate="true">Shipments Deleted</label>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <dataType>select</dataType>
            </settings>
        </column>
        <column name="deleted_by" sortOrder="100">
            <settings>
                <filter>text</filter>
                <label translate="true">Deleted By</label>
            </settings>
        </column>
        <column name="deletion_method" sortOrder="110">
            <settings>
                <filter>text</filter>
                <label translate="true">Method</label>
            </settings>
        </column>
        <column name="ip_address" sortOrder="120">
            <settings>
                <filter>text</filter>
                <label translate="true">IP Address</label>
            </settings>
        </column>
        <column name="deleted_at" class="Magento\Ui\Component\Listing\Columns\Date" sortOrder="130">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Deleted At</label>
                <dateFormat>MMM d, YYYY h:mm:ss A</dateFormat>
            </settings>
        </column>
    </columns>
</listing>
