    <div class="panth-oc-modal">
        <h3>&#9888; Delete Order #<?= /* @noEscape */ $incrementId ?>?</h3>

        <div class="panth-oc-warning">
            <strong>This action is permanent and cannot be undone.</strong>
            The following data will be permanently deleted:
            <ul style="margin:8px 0 0;padding-left:20px;">
                <li>Order #<?= /* @noEscape */ $incrementId ?> and all order items</li>
                <li>Related invoices, shipments, and credit memos</li>
                <li>Payment transactions and order history</li>
                <li>Associated quote data</li>
            </ul>
        </div>

        <?php if ($requireTypeId): ?>
            <label class="panth-oc-type-label">
                Type <strong><?= /* @noEscape */ $incrementId ?></strong> to confirm deletion:
            </label>
            <input type="text" class="panth-oc-type-input" id="panth-oc-type-input"
                   placeholder="Type order number here" autocomplete="off">
        <?php endif; ?>

        <div class="panth-oc-actions">
            <button type="button" class="panth-oc-cancel" id="panth-oc-cancel">Cancel</button>
            <form method="post" action="<?= $block->escapeUrl($deleteUrl) ?>" id="panth-oc-form" style="display:inline;">
                <input type="hidden" name="form_key" value="<?= /* @noEscape */ $formKey ?>">
                <input type="hidden" name="order_id" value="<?= (int) $block->getOrder()->getEntityId() ?>">
                <button type="submit" class="panth-oc-confirm <?= !$requireTypeId ? 'enabled' : '' ?>" id="panth-oc-confirm">
                    Yes, Permanently Delete
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var trigger = document.getElementById('panth-oc-delete-trigger');
    var modal = document.getElementById('panth-oc-modal');
    var cancelBtn = document.getElementById('panth-oc-cancel');
    var confirmBtn = document.getElementById('panth-oc-confirm');
    var typeInput = document.getElementById('panth-oc-type-input');
    var expectedId = '<?= $block->escapeJs($incrementId) ?>';
    var requireType = <?= $requireTypeId ? 'true' : 'false' ?>;
    var requireConfirm = <?= $requireConfirm ? 'true' : 'false' ?>;

    trigger.addEventListener('click', function() {
        if (!requireConfirm) {
            if (confirm('Are you sure you want to delete order #' + expectedId + '? This cannot be undone.')) {
                document.getElementById('panth-oc-form').submit();
            }
            return;
        }
        modal.classList.add('active');
        if (typeInput) typeInput.focus();
    });

    cancelBtn.addEventListener('click', function() {
        modal.classList.remove('active');
        if (typeInput) { typeInput.value = ''; confirmBtn.classList.remove('enabled'); }
    });

    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            modal.classList.remove('active');
            if (typeInput) { typeInput.value = ''; confirmBtn.classList.remove('enabled'); }
        }
    });

    if (typeInput) {
        typeInput.addEventListener('input', function() {
            var match = this.value.trim() === expectedId;
            confirmBtn.classList.toggle('enabled', match);
            this.classList.toggle('valid', match);
        });
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
            modal.classList.remove('active');
        }
    });
});
</script>
