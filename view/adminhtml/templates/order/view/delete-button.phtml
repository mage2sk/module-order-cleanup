<?php
/**
 * Delete button on Order View page with double-confirmation modal.
 *
 * @var \Panth\OrderCleanup\Block\Adminhtml\Order\View\DeleteButton $block
 */

if (!$block->canShow()) {
    return;
}

$deleteUrl = $block->getDeleteUrl();
$incrementId = $block->escapeHtml($block->getOrderIncrementId());
$buttonText = $block->escapeHtml($block->getButtonText());
$buttonColor = $block->escapeHtml($block->getButtonColor());
$requireConfirm = $block->requireConfirmation();
$requireTypeId = $block->requireTypeOrderId();
$formKey = $block->escapeHtml($block->getFormKey());
?>

<!-- Delete Button — uses native Magento admin button class -->
<button type="button"
        class="action-default scalable action-delete"
        id="panth-oc-delete-trigger"
        title="<?= $block->escapeHtmlAttr($buttonText) ?>">
    <span><?= /* @noEscape */ $buttonText ?></span>
</button>

<!-- Confirmation Modal -->
<div class="panth-oc-modal-backdrop" id="panth-oc-modal">
    <div class="panth-oc-modal">
        <h3>&#9888; Delete Order #<?= /* @noEscape */ $incrementId ?>?</h3>

        <div class="panth-oc-warning">
            <strong>This action is permanent and cannot be undone.</strong>
            The following data will be permanently deleted:
            <ul>
                <li>Order #<?= /* @noEscape */ $incrementId ?> and all order items</li>
                <li>Related invoices, shipments, and credit memos</li>
                <li>Payment transactions and order history</li>
                <li>Associated quote data</li>
            </ul>
        </div>

        <?php if ($requireTypeId): ?>
            <label class="panth-oc-type-label">
                Type <strong><?= /* @noEscape */ $incrementId ?></strong> to confirm deletion:
            </label>
            <input type="text" class="panth-oc-type-input" id="panth-oc-type-input"
                   placeholder="Type order number here" autocomplete="off">
        <?php endif; ?>

        <div class="panth-oc-actions">
            <button type="button" class="action-default scalable" id="panth-oc-cancel">
                <span>Cancel</span>
            </button>
            <form method="post" action="<?= $block->escapeUrl($deleteUrl) ?>" id="panth-oc-form" style="display:inline;">
                <input type="hidden" name="form_key" value="<?= /* @noEscape */ $formKey ?>">
                <input type="hidden" name="order_id" value="<?= (int) $block->getOrder()->getEntityId() ?>">
                <button type="submit" class="action-default scalable action-primary panth-oc-confirm" id="panth-oc-confirm" disabled>
                    <span>Yes, Permanently Delete</span>
                </button>
            </form>
        </div>
    </div>
</div>

